# Runtime environment for Unlim8ted OS on Linux ARM or x86 systems.
# Leave browser/backlight empty to allow auto-detection.
UNLIM8TED_BROWSER=
UNLIM8TED_DISPLAY=:0
UNLIM8TED_XAUTHORITY=/root/.Xauthority

# Set these after confirming the compositor/X11 output names on device.
UNLIM8TED_WLR_OUTPUT=
UNLIM8TED_XRANDR_OUTPUT=

# Override only if auto-detection does not find the right sysfs backlight.
UNLIM8TED_BACKLIGHT_PATH=

# Set to 1 if you want service startup to refresh the detected boot target.
UNLIM8TED_PLATFORM_AUTO_INSTALL=0
