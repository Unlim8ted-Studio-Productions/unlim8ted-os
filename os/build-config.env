#!/bin/sh

# Shared Buildroot settings for Unlim8ted OS.

UNLIM8TED_OS_DIR="${UNLIM8TED_OS_DIR:-$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)}"
UNLIM8TED_BUILDROOT_REPO="${UNLIM8TED_BUILDROOT_REPO:-https://git.buildroot.net/buildroot}"
UNLIM8TED_BUILDROOT_REF="${UNLIM8TED_BUILDROOT_REF:-2025.02.1}"
UNLIM8TED_BUILDROOT_DIR="${UNLIM8TED_BUILDROOT_DIR:-$UNLIM8TED_OS_DIR/build/buildroot-src}"
UNLIM8TED_EXTERNAL_DIR="${UNLIM8TED_EXTERNAL_DIR:-$UNLIM8TED_OS_DIR/buildroot-external}"
UNLIM8TED_OVERLAY_DIR="${UNLIM8TED_OVERLAY_DIR:-$UNLIM8TED_OS_DIR/overlay}"
UNLIM8TED_BUILD_DIR="${UNLIM8TED_BUILD_DIR:-$UNLIM8TED_OS_DIR/build}"
