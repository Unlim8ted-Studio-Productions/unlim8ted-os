# Python bytecode and caches
__pycache__/
*.py[cod]

# Editor and OS noise
.DS_Store
Thumbs.db

# Unlim8ted OS runtime state
os/opt/unlim8ted/logs/
os/opt/unlim8ted/state/captures/
os/opt/unlim8ted/state/chromium-profile/
os/opt/unlim8ted/state/*.json
!os/opt/unlim8ted/state/.gitkeep

# Canonical rootfs runtime state
os/rootfs/opt/unlim8ted/logs/
os/rootfs/opt/unlim8ted/state/captures/
os/rootfs/opt/unlim8ted/state/chromium-profile/
os/rootfs/opt/unlim8ted/state/*.json
!os/rootfs/opt/unlim8ted/state/.gitkeep

# Kernel source clones and build caches
os/build/work/
os/build/out/
os/build/initramfs/*.cpio
os/build/initramfs/*.cpio.gz
os/build/initramfs/*.img
!os/build/initramfs/initramfs-unlim8ted.img

# WSL/Linux-native kernel build cache
.cache/

# Boot artifacts generated by local kernel builds
os/bootfs/kernel/x86_64/vmlinuz-unlim8ted
os/bootfs/kernel/x86_64/initramfs-unlim8ted.img
os/bootfs/kernel/arm64/Image
os/bootfs/kernel/arm64/initramfs-unlim8ted.img
os/bootfs/rpi/broadcom/
os/bootfs/rpi/overlays/

# Local desktop session artifacts
os/root/.vnc/
os/rootfs/root/.vnc/
